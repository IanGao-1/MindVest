{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/es.iterator.reduce.js\";\nimport * as echarts from 'echarts';\nimport { fetchAssets, fetchQuote } from './services/api';\nexport default {\n  name: 'App',\n  data() {\n    return {\n      assets: [],\n      quote: null,\n      tickerInput: 'TSLA',\n      loading: false,\n      quoteLoading: false,\n      error: '',\n      quoteError: '',\n      charts: {\n        type: null,\n        quote: null\n      }\n    };\n  },\n  computed: {\n    totalMarketValue() {\n      return this.assets.reduce((sum, asset) => sum + this.assetValue(asset), 0);\n    },\n    quoteTrendClass() {\n      return this.quote?.change >= 0 ? 'text-rise' : 'text-fall';\n    }\n  },\n  mounted() {\n    this.loadDashboard();\n    window.addEventListener('resize', this.handleResize);\n  },\n  beforeDestroy() {\n    window.removeEventListener('resize', this.handleResize);\n    Object.values(this.charts).forEach(c => c?.dispose());\n  },\n  methods: {\n    async loadDashboard() {\n      this.loading = true;\n      this.error = '';\n      try {\n        await this.refreshAssets();\n        this.$nextTick(() => {\n          this.renderTypeChart();\n        });\n        if (!this.quote) {\n          this.searchQuote();\n        }\n      } catch (e) {\n        this.error = `Load failed: ${e.message}`;\n      } finally {\n        this.loading = false;\n      }\n    },\n    async searchQuote() {\n      if (!this.tickerInput) return;\n      this.quoteLoading = true;\n      this.quoteError = '';\n      try {\n        this.quote = await fetchQuote(this.tickerInput);\n        this.$nextTick(() => this.renderQuoteChart());\n      } catch (e) {\n        this.quoteError = `Quote failed: ${e.message}`;\n      } finally {\n        this.quoteLoading = false;\n      }\n    },\n    assetValue(asset) {\n      return Number(asset.currentPrice || 0) * Number(asset.quantity || 0);\n    },\n    async refreshAssets() {\n      const assets = await fetchAssets();\n      this.assets = Array.isArray(assets) ? assets : [];\n    },\n    formatCurrency(v) {\n      return v == null ? '--' : new Intl.NumberFormat('zh-CN', {\n        style: 'currency',\n        currency: 'USD'\n      }).format(v);\n    },\n    formatNumber(v) {\n      return v == null ? '--' : Number(v).toFixed(2);\n    },\n    formatSigned(v) {\n      if (v == null || Number.isNaN(Number(v))) return '--';\n      return Number(v) >= 0 ? `+${Number(v).toFixed(2)}` : Number(v).toFixed(2);\n    },\n    getChartInst(key, el) {\n      if (!this.charts[key] && el) this.charts[key] = echarts.init(el);\n      return this.charts[key];\n    },\n    renderTypeChart() {\n      const c = this.getChartInst('type', this.$refs.typeChart);\n      if (!c) return;\n      const group = {};\n      this.assets.forEach(a => {\n        group[a.type] = (group[a.type] || 0) + this.assetValue(a);\n      });\n      c.setOption({\n        tooltip: {\n          trigger: 'item'\n        },\n        series: [{\n          type: 'pie',\n          radius: ['40%', '70%'],\n          data: Object.entries(group).map(([k, v]) => ({\n            name: k,\n            value: v\n          }))\n        }]\n      });\n    },\n    renderQuoteChart() {\n      const c = this.getChartInst('quote', this.$refs.quoteChart);\n      if (!c || !this.quote) return;\n      const data = [this.quote.open, this.quote.previousClose, this.quote.dayLow, this.quote.dayHigh, this.quote.price];\n      c.setOption({\n        xAxis: {\n          data: ['Open', 'Prev Close', 'Low', 'High', 'Price']\n        },\n        yAxis: {\n          type: 'value'\n        },\n        series: [{\n          type: 'line',\n          smooth: true,\n          data\n        }]\n      });\n    },\n    handleResize() {\n      Object.values(this.charts).forEach(c => c?.resize());\n    }\n  }\n};","map":{"version":3,"names":["echarts","fetchAssets","fetchQuote","name","data","assets","quote","tickerInput","loading","quoteLoading","error","quoteError","charts","type","computed","totalMarketValue","reduce","sum","asset","assetValue","quoteTrendClass","change","mounted","loadDashboard","window","addEventListener","handleResize","beforeDestroy","removeEventListener","Object","values","forEach","c","dispose","methods","refreshAssets","$nextTick","renderTypeChart","searchQuote","e","message","renderQuoteChart","Number","currentPrice","quantity","Array","isArray","formatCurrency","v","Intl","NumberFormat","style","currency","format","formatNumber","toFixed","formatSigned","isNaN","getChartInst","key","el","init","$refs","typeChart","group","a","setOption","tooltip","trigger","series","radius","entries","map","k","value","quoteChart","open","previousClose","dayLow","dayHigh","price","xAxis","yAxis","smooth","resize"],"sources":["src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app\" class=\"app-shell\">\n    <section class=\"hero\">\n      <div>\n        <p class=\"eyebrow\">Financial Management Dashboard</p>\n        <h1>Assets and Market Snapshot</h1>\n        <p class=\"hero-copy\">\n          The dashboard connects to the Spring Boot backend and displays tracked\n          assets and live quote data with ECharts.\n        </p>\n      </div>\n      <button class=\"refresh-button\" :disabled=\"loading\" @click=\"loadDashboard\">\n        {{ loading ? 'Loading...' : 'Refresh' }}\n      </button>\n    </section>\n\n    <section v-if=\"error\" class=\"error-banner\">\n      {{ error }}\n    </section>\n\n    <section class=\"summary-grid\">\n      <article class=\"summary-card accent-card\">\n        <span class=\"summary-label\">assets</span>\n        <strong>{{ assets.length }}</strong>\n        <small>Total assets currently tracked</small>\n      </article>\n      <article class=\"summary-card\">\n        <span class=\"summary-label\">market value</span>\n        <strong>{{ formatCurrency(totalMarketValue) }}</strong>\n        <small>Estimated by current price × quantity</small>\n      </article>\n    </section>\n\n    <section class=\"content-grid\">\n      <article class=\"panel quote-panel\">\n        <div class=\"panel-heading\">\n          <div>\n            <p class=\"panel-kicker\">quote</p>\n            <h2>Yahoo Finance / Fallback</h2>\n          </div>\n        </div>\n\n        <form class=\"quote-form\" @submit.prevent=\"searchQuote\">\n          <label>\n            <span>Ticker</span>\n            <input v-model.trim=\"tickerInput\" type=\"text\" placeholder=\"AAPL or 0700.HK\">\n          </label>\n          <button type=\"submit\" :disabled=\"quoteLoading\">\n            {{ quoteLoading ? 'Loading...' : 'Search' }}\n          </button>\n        </form>\n\n        <div v-if=\"quoteError\" class=\"inline-error\">{{ quoteError }}</div>\n\n        <div v-if=\"quote\" class=\"quote-metrics\">\n          <div class=\"metric-box\">\n            <span>Price</span>\n            <strong>{{ formatCurrency(quote.price) }}</strong>\n          </div>\n          <div class=\"metric-box\">\n            <span>Change</span>\n            <strong :class=\"quoteTrendClass\">{{ formatSigned(quote.change) }}</strong>\n          </div>\n          <div class=\"metric-box\">\n            <span>Source</span>\n            <strong>{{ quote.source || 'unknown' }}</strong>\n          </div>\n          <div class=\"metric-box\">\n            <span>Time</span>\n            <strong>{{ quote.latestTimestamp || 'realtime' }}</strong>\n          </div>\n        </div>\n        <div ref=\"quoteChart\" class=\"chart chart-medium\"></div>\n      </article>\n\n      <article class=\"panel\">\n        <div class=\"panel-heading\">\n          <div>\n            <p class=\"panel-kicker\">distribution</p>\n            <h2>Asset Type Breakdown</h2>\n          </div>\n        </div>\n        <div ref=\"typeChart\" class=\"chart\"></div>\n      </article>\n    </section>\n\n    <section class=\"tables-grid\">\n      <article class=\"panel\">\n        <div class=\"panel-heading\">\n          <div>\n            <p class=\"panel-kicker\">assets</p>\n            <h2>Assets</h2>\n          </div>\n        </div>\n        <div class=\"table-wrap\">\n          <table>\n            <thead>\n              <tr>\n                <th>Ticker</th>\n                <th>Name</th>\n                <th>Type</th>\n                <th>Quantity</th>\n                <th>Buy Price</th>\n                <th>Current Price</th>\n                <th>Market Value</th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr v-for=\"asset in assets\" :key=\"asset.id\">\n                <td>{{ asset.ticker }}</td>\n                <td>{{ asset.name }}</td>\n                <td>{{ asset.type }}</td>\n                <td>{{ formatNumber(asset.quantity) }}</td>\n                <td>{{ formatCurrency(asset.buyPrice) }}</td>\n                <td>{{ formatCurrency(asset.currentPrice) }}</td>\n                <td>{{ formatCurrency(assetValue(asset)) }}</td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </article>\n    </section>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\nimport { fetchAssets, fetchQuote } from './services/api'\n\nexport default {\n  name: 'App',\n  data() {\n    return {\n      assets: [],\n      quote: null,\n      tickerInput: 'TSLA',\n      loading: false,\n      quoteLoading: false,\n      error: '',\n      quoteError: '',\n      charts: { type: null, quote: null }\n    }\n  },\n  computed: {\n    totalMarketValue() {\n      return this.assets.reduce((sum, asset) => sum + this.assetValue(asset), 0)\n    },\n    quoteTrendClass() {\n      return this.quote?.change >= 0 ? 'text-rise' : 'text-fall'\n    }\n  },\n  mounted() {\n    this.loadDashboard()\n    window.addEventListener('resize', this.handleResize)\n  },\n  beforeDestroy() {\n    window.removeEventListener('resize', this.handleResize)\n    Object.values(this.charts).forEach(c => c?.dispose())\n  },\n  methods: {\n    async loadDashboard() {\n      this.loading = true\n      this.error = ''\n      try {\n        await this.refreshAssets()\n        this.$nextTick(() => {\n          this.renderTypeChart()\n        })\n        if (!this.quote) {\n          this.searchQuote()\n        }\n      } catch (e) {\n        this.error = `Load failed: ${e.message}`\n      } finally {\n        this.loading = false\n      }\n    },\n    async searchQuote() {\n      if (!this.tickerInput) return\n      this.quoteLoading = true\n      this.quoteError = ''\n      try {\n        this.quote = await fetchQuote(this.tickerInput)\n        this.$nextTick(() => this.renderQuoteChart())\n      } catch (e) {\n        this.quoteError = `Quote failed: ${e.message}`\n      } finally {\n        this.quoteLoading = false\n      }\n    },\n    assetValue(asset) {\n      return Number(asset.currentPrice || 0) * Number(asset.quantity || 0)\n    },\n    async refreshAssets() {\n      const assets = await fetchAssets()\n      this.assets = Array.isArray(assets) ? assets : []\n    },\n    formatCurrency(v) {\n      return v == null ? '--' : new Intl.NumberFormat('zh-CN', {\n        style: 'currency',\n        currency: 'USD'\n      }).format(v)\n    },\n    formatNumber(v) {\n      return v == null ? '--' : Number(v).toFixed(2)\n    },\n    formatSigned(v) {\n      if (v == null || Number.isNaN(Number(v))) return '--'\n      return Number(v) >= 0 ? `+${Number(v).toFixed(2)}` : Number(v).toFixed(2)\n    },\n    getChartInst(key, el) {\n      if (!this.charts[key] && el) this.charts[key] = echarts.init(el)\n      return this.charts[key]\n    },\n    renderTypeChart() {\n      const c = this.getChartInst('type', this.$refs.typeChart)\n      if (!c) return\n      const group = {}\n      this.assets.forEach((a) => {\n        group[a.type] = (group[a.type] || 0) + this.assetValue(a)\n      })\n      c.setOption({\n        tooltip: { trigger: 'item' },\n        series: [\n          {\n            type: 'pie',\n            radius: ['40%', '70%'],\n            data: Object.entries(group).map(([k, v]) => ({ name: k, value: v }))\n          }\n        ]\n      })\n    },\n    renderQuoteChart() {\n      const c = this.getChartInst('quote', this.$refs.quoteChart)\n      if (!c || !this.quote) return\n      const data = [\n        this.quote.open,\n        this.quote.previousClose,\n        this.quote.dayLow,\n        this.quote.dayHigh,\n        this.quote.price\n      ]\n      c.setOption({\n        xAxis: { data: ['Open', 'Prev Close', 'Low', 'High', 'Price'] },\n        yAxis: { type: 'value' },\n        series: [{ type: 'line', smooth: true, data }]\n      })\n    },\n    handleResize() {\n      Object.values(this.charts).forEach(c => c?.resize())\n    }\n  }\n}\n</script>\n\n<style>\n:root {\n  --bg: #06101d;\n  --panel: rgba(10, 23, 42, 0.88);\n  --line: rgba(126, 156, 199, 0.2);\n  --text: #eef4ff;\n  --muted: #9db1d0;\n  --accent: #39d0a4;\n  --danger: #ff7a7a;\n}\n\n* {\n  box-sizing: border-box;\n}\n\nbody {\n  margin: 0;\n  background: #07111f;\n  color: var(--text);\n  font-family: sans-serif;\n}\n\n.app-shell {\n  min-height: 100vh;\n  padding: 32px;\n}\n\n.hero {\n  display: flex;\n  justify-content: space-between;\n  gap: 24px;\n  align-items: flex-start;\n  padding: 28px;\n  border-radius: 28px;\n  background: rgba(12, 31, 57, 0.95);\n}\n\n.eyebrow,\n.summary-label,\n.panel-kicker {\n  color: var(--accent);\n  font-size: 12px;\n  letter-spacing: 0.18em;\n  text-transform: uppercase;\n}\n\n.hero h1 {\n  font-size: 42px;\n  margin: 10px 0;\n}\n\n.hero-copy {\n  color: var(--muted);\n  line-height: 1.7;\n  max-width: 680px;\n}\n\n.refresh-button {\n  padding: 14px 22px;\n  border-radius: 999px;\n  background: linear-gradient(90deg, #39d0a4, #2b7fff);\n  border: none;\n  font-weight: bold;\n  cursor: pointer;\n}\n\n.error-banner,\n.inline-error {\n  background: rgba(255, 122, 122, 0.2);\n  padding: 14px;\n  border-radius: 18px;\n  margin: 20px 0;\n  color: #ffd4d4;\n}\n\n.summary-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 20px;\n  margin: 20px 0;\n}\n\n.summary-card {\n  padding: 22px;\n  background: var(--panel);\n  border-radius: 24px;\n  border: 1px solid var(--line);\n}\n\n.accent-card {\n  background: rgba(57, 208, 164, 0.1);\n}\n\n.summary-card strong {\n  font-size: 34px;\n  display: block;\n  margin: 8px 0;\n}\n\n.content-grid {\n  display: grid;\n  grid-template-columns: 1.2fr 1fr;\n  gap: 20px;\n  margin: 20px 0;\n}\n\n.panel {\n  background: var(--panel);\n  border-radius: 24px;\n  padding: 22px;\n  border: 1px solid var(--line);\n}\n\n.panel-heading {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 16px;\n}\n\n.chart {\n  width: 100%;\n  height: 340px;\n}\n\n.chart-medium {\n  height: 280px;\n}\n\n.quote-form {\n  display: flex;\n  gap: 14px;\n  margin-bottom: 18px;\n}\n\n.quote-form label {\n  width: 100%;\n}\n\n.quote-form span {\n  display: block;\n  margin-bottom: 8px;\n}\n\n.quote-form input,\n.form-group input {\n  width: 100%;\n  background: rgba(255, 255, 255, 0.04);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  padding: 14px;\n  border-radius: 14px;\n  color: #fff;\n}\n\n.quote-form button {\n  padding: 14px 22px;\n  border-radius: 999px;\n  background: linear-gradient(90deg, #39d0a4, #2b7fff);\n  border: none;\n  font-weight: bold;\n  cursor: pointer;\n}\n\n.quote-metrics {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 12px;\n}\n\n.metric-box {\n  padding: 14px;\n  background: rgba(255, 255, 255, 0.04);\n  border-radius: 18px;\n}\n\n.tables-grid {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 20px;\n  margin: 20px 0;\n}\n\n.table-wrap {\n  overflow-x: auto;\n}\n\ntable {\n  width: 100%;\n  border-collapse: collapse;\n}\n\nth,\ntd {\n  padding: 14px;\n  text-align: left;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.07);\n}\n\n.text-rise {\n  color: #39d0a4;\n}\n\n.text-fall {\n  color: #ff7a7a;\n}\n\n@media (max-width: 1200px) {\n  .summary-grid,\n  .content-grid,\n  .tables-grid,\n  .quote-metrics {\n    grid-template-columns: repeat(2, 1fr);\n  }\n}\n\n@media (max-width: 768px) {\n  .app-shell {\n    padding: 16px;\n  }\n\n  .hero,\n  .summary-grid,\n  .content-grid,\n  .tables-grid,\n  .quote-metrics {\n    grid-template-columns: 1fr;\n  }\n\n  .hero {\n    display: block;\n  }\n\n  .quote-form {\n    flex-direction: column;\n  }\n}\n</style>\n"],"mappings":";;;;AA8HA,YAAAA,OAAA;AACA,SAAAC,WAAA,EAAAC,UAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,MAAA;MACAC,KAAA;MACAC,WAAA;MACAC,OAAA;MACAC,YAAA;MACAC,KAAA;MACAC,UAAA;MACAC,MAAA;QAAAC,IAAA;QAAAP,KAAA;MAAA;IACA;EACA;EACAQ,QAAA;IACAC,iBAAA;MACA,YAAAV,MAAA,CAAAW,MAAA,EAAAC,GAAA,EAAAC,KAAA,KAAAD,GAAA,QAAAE,UAAA,CAAAD,KAAA;IACA;IACAE,gBAAA;MACA,YAAAd,KAAA,EAAAe,MAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,aAAA;IACAC,MAAA,CAAAC,gBAAA,gBAAAC,YAAA;EACA;EACAC,cAAA;IACAH,MAAA,CAAAI,mBAAA,gBAAAF,YAAA;IACAG,MAAA,CAAAC,MAAA,MAAAlB,MAAA,EAAAmB,OAAA,CAAAC,CAAA,IAAAA,CAAA,EAAAC,OAAA;EACA;EACAC,OAAA;IACA,MAAAX,cAAA;MACA,KAAAf,OAAA;MACA,KAAAE,KAAA;MACA;QACA,WAAAyB,aAAA;QACA,KAAAC,SAAA;UACA,KAAAC,eAAA;QACA;QACA,UAAA/B,KAAA;UACA,KAAAgC,WAAA;QACA;MACA,SAAAC,CAAA;QACA,KAAA7B,KAAA,mBAAA6B,CAAA,CAAAC,OAAA;MACA;QACA,KAAAhC,OAAA;MACA;IACA;IACA,MAAA8B,YAAA;MACA,UAAA/B,WAAA;MACA,KAAAE,YAAA;MACA,KAAAE,UAAA;MACA;QACA,KAAAL,KAAA,SAAAJ,UAAA,MAAAK,WAAA;QACA,KAAA6B,SAAA,YAAAK,gBAAA;MACA,SAAAF,CAAA;QACA,KAAA5B,UAAA,oBAAA4B,CAAA,CAAAC,OAAA;MACA;QACA,KAAA/B,YAAA;MACA;IACA;IACAU,WAAAD,KAAA;MACA,OAAAwB,MAAA,CAAAxB,KAAA,CAAAyB,YAAA,SAAAD,MAAA,CAAAxB,KAAA,CAAA0B,QAAA;IACA;IACA,MAAAT,cAAA;MACA,MAAA9B,MAAA,SAAAJ,WAAA;MACA,KAAAI,MAAA,GAAAwC,KAAA,CAAAC,OAAA,CAAAzC,MAAA,IAAAA,MAAA;IACA;IACA0C,eAAAC,CAAA;MACA,OAAAA,CAAA,sBAAAC,IAAA,CAAAC,YAAA;QACAC,KAAA;QACAC,QAAA;MACA,GAAAC,MAAA,CAAAL,CAAA;IACA;IACAM,aAAAN,CAAA;MACA,OAAAA,CAAA,kBAAAN,MAAA,CAAA